{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticPrefixChore",
    "schedule:weekly",
    ":assignee(jimsynz)",
    ":rebaseStalePrs",
    ":enableVulnerabilityAlerts",
    ":disableDependencyDashboard"
  ],
  "rebaseWhen": "behind-base-branch",
  "enabledManagers": ["asdf", "github-actions"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "schedule": ["before 4am"]
    }
  ]
}
