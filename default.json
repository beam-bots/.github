{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticPrefixChore",
    "schedule:weekly",
    ":assignee(jimsynz)",
    ":rebaseStalePrs",
    ":enableVulnerabilityAlerts",
    ":disableDependencyDashboard"
  ],
  "rebaseWhen": "behind-base-branch",
  "enabledManagers": ["asdf", "github-actions", "custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["zola (?<currentValue>\\S+)"],
      "depNameTemplate": "zola",
      "packageNameTemplate": "getzola/zola",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["pipx (?<currentValue>\\S+)"],
      "depNameTemplate": "pipx",
      "datasourceTemplate": "pypi"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "schedule": ["before 4am"]
    },
    {
      "matchFileNames": ["**/.tool-versions"],
      "groupName": "tool-versions",
      "separateMajorMinor": false
    }
  ]
}
